{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "title": "yutu",
  "name": "io.github.eat-pray-ai/yutu",
  "description": "The AI-powered toolkit that grows your YouTube channel on autopilot",
  "icons": [
    {
      "mimeType": "image/svg+xml",
      "sizes": [
        "any"
      ],
      "src": "https://raw.githubusercontent.com/eat-pray-ai/yutu/main/assets/yutu-ico.svg"
    }
  ],
  "repository": {
    "url": "https://github.com/eat-pray-ai/yutu",
    "source": "github",
    "id": "643163403"
  },
  "version": "0.0.0-dev",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@eat-pray-ai/yutu",
      "version": "0.0.0-dev",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "named",
          "name": "--mode",
          "value": "stdio"
        }
      ],
      "environmentVariables": [
        {
          "description": "GCP project credential for yutu, base64 encoded JSON or path to JSON file",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YUTU_CREDENTIAL"
        },
        {
          "description": "YouTube authentication token, base64 encoded JSON or path to JSON file",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YUTU_CACHE_TOKEN"
        },
        {
          "description": "Log level",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "YUTU_LOG_LEVEL",
          "default": "INFO",
          "choices": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR"
          ]
        }
      ]
    },
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@eat-pray-ai/yutu",
      "version": "0.0.0-dev",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:{--port}/mcp",
        "authorization": {
          "type": "oauth2",
          "authorizationServers": ["https://accounts.google.com"],
          "scopes": [
            "https://www.googleapis.com/auth/youtube",
            "https://www.googleapis.com/auth/youtube.force-ssl",
            "https://www.googleapis.com/auth/youtube.channel-memberships.creator"
          ]
        }
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "named",
          "name": "--mode",
          "value": "http"
        },
        {
          "type": "named",
          "name": "--port",
          "description": "Port to listen on for HTTP mode",
          "default": "8216"
        }
      ],
      "environmentVariables": [
        {
          "description": "GCP project credential for yutu, base64 encoded JSON or path to JSON file",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YUTU_CREDENTIAL"
        },
        {
          "description": "YouTube authentication token, base64 encoded JSON or path to JSON file",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YUTU_CACHE_TOKEN"
        },
        {
          "description": "Log level",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "YUTU_LOG_LEVEL",
          "default": "INFO",
          "choices": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR"
          ]
        }
      ]
    }
  ]
}
